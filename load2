-- ══════════════════════════════════════════
-- EVENT HANDLERS
-- ══════════════════════════════════════════
savePosBtn.MouseButton1Click:Connect(function()
    local c = lp.Character
    if not c then return end
    local r = c:FindFirstChild("HumanoidRootPart")
    if not r then return end
    BOT.savePos(State.selectedEggName, r.Position)
    savePosBtn.Text = "[v] Saved!"
    task.delay(2, function() savePosBtn.Text = "[+] Save Current Position" end)
end)

local _, getHatchBox = W.strInput("Egg Name", State.selectedEggName)
local changeEggBtn = W.actionBtn("[>] Change Egg", P.amber)
changeEggBtn.MouseButton1Click:Connect(function()
    local name = getHatchBox.Text:match("^%s*(.-)%s*$")
    if name and name ~= "" then
        BOT.selectEgg(name)
        eggLbl.Text = name
        changeEggBtn.Text = "[v] Changed!"
        task.delay(2, function() changeEggBtn.Text = "[>] Change Egg" end)
    end
end)

W.gap()
forceHatchToggle(State.hatchRunning)
local function setupHatchToggle()
    local _, getState, setCb, forceToggle = W.toggle("Auto Hatch", State.hatchRunning, P.lime)
    setCb(function(on)
        if on then
            BOT.startHatch()
        else
            BOT.stopHatch()
        end
    end)
    task.spawn(function()
        while task.wait(0.5) do
            if getState() ~= State.hatchRunning then
                forceToggle(State.hatchRunning)
            end
        end
    end)
end

setWebhookCb(function(on)
    State.webhookEnabled = on
end)
webhookBox.FocusLost:Connect(function()
    if webhookBox.Text ~= "" then
        State.webhookUrl = webhookBox.Text
        BOT.log("UI", "Webhook URL updated")
    end
end)

-- ══════════════════════════════════════════
-- STATUS UPDATE LOOP
-- ══════════════════════════════════════════
task.spawn(function()
    while task.wait(0.5) do
        statusLbl.Text = State.action
        
        if State.hatchRunning then
            statusLbl.TextColor3 = P.lime
            statusAcc.BackgroundColor3 = P.lime
        else
            statusLbl.TextColor3 = P.muted
            statusAcc.BackgroundColor3 = P.muted
        end
        
        hatchedLbl.Text = tostring(State.totalHatched)
        lastLbl.Text = State.lastHatched or "—"
        
        if getHatchState() ~= State.hatchRunning then
            forceHatchToggle(State.hatchRunning)
        end
    end
end)


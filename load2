-- ══════════════════════════════════════════
-- WIDGET FACTORY
-- ══════════════════════════════════════════
local function makeWidgets(parent)
    local lo = 0
    local w = {}
    
    function w.section(txt, col)
        lo += 1
        local f = Instance.new("Frame", parent)
        f.Size = UDim2.new(1, 0, 0, 16)
        f.BackgroundTransparency = 1
        f.LayoutOrder = lo
        local bar = Instance.new("Frame", f)
        bar.Size = UDim2.fromOffset(2, 9)
        bar.Position = UDim2.fromOffset(0, 3)
        bar.BackgroundColor3 = col or P.cyan
        bar.BorderSizePixel = 0
        Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)
        local l = Instance.new("TextLabel", f)
        l.Size = UDim2.new(1, -8, 1, 0)
        l.Position = UDim2.fromOffset(7, 0)
        l.BackgroundTransparency = 1
        l.Text = txt:upper()
        l.TextColor3 = col or P.cyan
        l.TextSize = 7
        l.Font = Enum.Font.GothamBold
        l.TextXAlignment = Enum.TextXAlignment.Left
        return f
    end
    
    function w.toggle(label, defaultOn, ac)
        lo += 1
        ac = ac or P.cyan
        local f = Instance.new("Frame", parent)
        f.Size = UDim2.new(1, 0, 0, 28)
        f.BackgroundColor3 = P.tile
        f.BorderSizePixel = 0
        f.LayoutOrder = lo
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 7)
        local stroke = Instance.new("UIStroke", f)
        stroke.Color = defaultOn and ac or P.line
        stroke.Thickness = 1
        local nameLbl = Instance.new("TextLabel", f)
        nameLbl.Size = UDim2.new(1, -52, 1, 0)
        nameLbl.Position = UDim2.fromOffset(10, 0)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text = label
        nameLbl.TextColor3 = defaultOn and P.txt or P.muted
        nameLbl.TextSize = 9
        nameLbl.Font = Enum.Font.GothamBold
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        local track = Instance.new("Frame", f)
        track.Size = UDim2.fromOffset(34, 16)
        track.Position = UDim2.new(1, -40, 0.5, -8)
        track.BackgroundColor3 = defaultOn and ac or P.line
        track.BorderSizePixel = 0
        Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
        local knob = Instance.new("Frame", track)
        knob.Size = UDim2.fromOffset(10, 10)
        knob.Position = defaultOn and UDim2.fromOffset(21, 3) or UDim2.fromOffset(3, 3)
        knob.BackgroundColor3 = defaultOn and P.bg or P.muted
        knob.BorderSizePixel = 0
        Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
        local state = defaultOn
        local cb = nil
        local function setState(val)
            state = val
            track.BackgroundColor3 = val and ac or P.line
            knob.Position = val and UDim2.fromOffset(21, 3) or UDim2.fromOffset(3, 3)
            knob.BackgroundColor3 = val and P.bg or P.muted
            stroke.Color = val and ac or P.line
            nameLbl.TextColor3 = val and P.txt or P.muted
            if cb then cb(val) end
        end
        local hit = Instance.new("TextButton", f)
        hit.Size = UDim2.fromScale(1, 1)
        hit.BackgroundTransparency = 1
        hit.Text = ""
        hit.ZIndex = 13
        hit.MouseButton1Click:Connect(function() setState(not state) end)
        return f,
            function() return state end,
            function(fn) cb = fn end,
            function(val) setState(val) end
    end
    
    function w.infoRow(label, val)
        lo += 1
        local f = Instance.new("Frame", parent)
        f.Size = UDim2.new(1, 0, 0, 20)
        f.BackgroundColor3 = P.tile
        f.BorderSizePixel = 0
        f.LayoutOrder = lo
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 5)
        local lk = Instance.new("TextLabel", f)
        lk.Size = UDim2.new(0.58, 0, 1, 0)
        lk.Position = UDim2.fromOffset(8, 0)
        lk.BackgroundTransparency = 1
        lk.Text = label
        lk.TextColor3 = P.muted
        lk.TextSize = 8
        lk.Font = Enum.Font.Gotham
        lk.TextXAlignment = Enum.TextXAlignment.Left
        local lv = Instance.new("TextLabel", f)
        lv.Size = UDim2.new(0.42, -6, 1, 0)
        lv.Position = UDim2.new(0.58, 0, 0, 0)
        lv.BackgroundTransparency = 1
        lv.Text = val or "-"
        lv.TextColor3 = P.txt
        lv.TextSize = 8
        lv.Font = Enum.Font.GothamBold
        lv.TextXAlignment = Enum.TextXAlignment.Right
        return f, lk, lv
    end
    
    function w.actionBtn(label, col)
        lo += 1
        local ac = col or P.tile
        local b = Instance.new("TextButton", parent)
        b.Size = UDim2.new(1, 0, 0, 26)
        b.BackgroundColor3 = ac
        b.BackgroundTransparency = 0.78
        b.BorderSizePixel = 0
        b.Text = label
        b.TextColor3 = P.txt
        b.TextSize = 8
        b.Font = Enum.Font.GothamBold
        b.LayoutOrder = lo
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
        do local st = Instance.new("UIStroke", b) st.Color = ac st.Thickness = 1 st.Transparency = 0.55 end
        return b
    end
    
    function w.gap(h)
        lo += 1
        local f = Instance.new("Frame", parent)
        f.Size = UDim2.new(1, 0, 0, h or 4)
        f.BackgroundTransparency = 1
        f.LayoutOrder = lo
    end
    
    function w.strInput(label, default)
        lo += 1
        local f = Instance.new("Frame", parent)
        f.Size = UDim2.new(1, 0, 0, 24)
        f.BackgroundColor3 = P.tile
        f.BorderSizePixel = 0
        f.LayoutOrder = lo
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
        local l = Instance.new("TextLabel", f)
        l.Size = UDim2.new(0.42, 0, 1, 0)
        l.Position = UDim2.fromOffset(8, 0)
        l.BackgroundTransparency = 1
        l.Text = label
        l.TextColor3 = P.muted
        l.TextSize = 8
        l.Font = Enum.Font.Gotham
        l.TextXAlignment = Enum.TextXAlignment.Left
        local box = Instance.new("TextBox", f)
        box.Size = UDim2.new(0.58, -8, 0.7, 0)
        box.Position = UDim2.new(0.42, 4, 0.15, 0)
        box.BackgroundColor3 = P.card
        box.BorderSizePixel = 0
        box.Text = tostring(default)
        box.TextColor3 = P.txt
        box.TextSize = 8
        box.Font = Enum.Font.GothamBold
        box.ClearTextOnFocus = false
        Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
        return f, box
    end
    
    function w.pill(txt, col)
        lo += 1
        local f = Instance.new("Frame", parent)
        f.Size = UDim2.new(1, 0, 0, 24)
        f.BackgroundColor3 = P.tile
        f.BorderSizePixel = 0
        f.LayoutOrder = lo
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
        do local st = Instance.new("UIStroke", f) st.Color = P.line st.Thickness = 1 end
        local l = Instance.new("TextLabel", f)
        l.Size = UDim2.new(1, -12, 1, 0)
        l.Position = UDim2.fromOffset(9, 0)
        l.BackgroundTransparency = 1
        l.Text = txt
        l.TextColor3 = col or P.muted
        l.TextSize = 9
        l.Font = Enum.Font.Gotham
        l.TextXAlignment = Enum.TextXAlignment.Left
        l.TextWrapped = true
        return l
    end
    
    return w
end


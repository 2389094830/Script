-- ══════════════════════════════════════════
-- EGG DETECTION
-- ══════════════════════════════════════════
local function findEggsInWorkspace()
    local eggs = {}
    local eggsFolder = workspace:FindFirstChild("Eggs")
    
    if eggsFolder then
        for _, egg in pairs(eggsFolder:GetChildren()) do
            if egg:IsA("Model") or egg:IsA("BasePart") then
                table.insert(eggs, egg)
            end
        end
    end
    
    -- Also scan workspace for limited eggs
    for _, child in pairs(workspace:GetChildren()) do
        if child.Name:match("Egg") and not child:IsDescendantOf(eggsFolder or workspace:FindFirstChild("Camera")) then
            if not table.find(eggs, child) then
                table.insert(eggs, child)
            end
        end
    end
    
    return eggs
end

local function getEggInfo(egg)
    local pos = egg:IsA("BasePart") and egg.Position or 
                (egg.PrimaryPart and egg.PrimaryPart.Position) or
                Vector3.new()
    
    return {
        Model = egg,
        Name = egg.Name,
        Position = pos,
        Distance = (pos - character:FindFirstChild("HumanoidRootPart").Position).Magnitude,
        UniqueId = egg:GetFullName(),
    }
end

local function findNearestEgg(eggName)
    local eggs = findEggsInWorkspace()
    local nearest = nil
    local nearestDist = math.huge
    
    for _, egg in pairs(eggs) do
        if egg.Name == eggName then
            local info = getEggInfo(egg)
            if info.Distance < nearestDist then
                nearestDist = info.Distance
                nearest = info
            end
        end
    end
    
    return nearest
end


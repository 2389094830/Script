        log("TP", "SKIPPED — no HRP | " .. tostring(reason)) 
        return 
    end
    local curPos = r.Position
    log("TP", string.format("%s -> %.1f,%.1f,%.1f", tostring(reason), pos.X, pos.Y, pos.Z))
    r.CFrame = CFrame.new(pos)
    task.wait(0.05)
end


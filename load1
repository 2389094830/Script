-- WEBHOOK SYSTEM
-- ══════════════════════════════════════════
local _webhookCooldown = {}

local function sendWebhookEmbed(petName, variantPrefix)
    if not State.webhookEnabled or not State.webhookUrl or State.webhookUrl == "" then 
        return false 
    end
    
    local unixNow = DateTime.now().UnixTimestamp
    local payload = {
        embeds = {{
            title = string.format("🔮 %s%s", variantPrefix or "", petName),
            description = string.format("**%s** just hatched this! <t:%d:R>", lp.Name, unixNow),
            color = 0x9B4BFF,
            footer = { text = "AutoBot • " .. lp.Name },
        }}
    }
    
    local ok = pcall(function()
        local reqFn = (syn and syn.request) or (http and http.request) or request
        if reqFn then
            reqFn({
                Url = State.webhookUrl,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = HttpService:JSONEncode(payload)
            })
        end
    end)
    
    return ok
end

-- Hook into hatching to detect pets
do
    local ok, HM = pcall(function()
        return require(game:GetService("ReplicatedStorage"):WaitForChild("Client", 10)
            :WaitForChild("Effects", 10):WaitForChild("HatchEgg", 10))
    end)
    
    if ok and HM and type(HM.Play) == "function" then
        local orig = HM.Play
        pcall(hookfunction, HM.Play, newcclosure(function(self, data)
            if data and data.Pets and State.webhookEnabled then
                for _, pe in ipairs(data.Pets) do
                    local pet = pe and pe.Pet
                    if pet and pet.Name then
                        local now = tick()
                        local key = pet.Name .. (pet.Shiny and "_shiny" or "") .. (pet.Mythic and "_mythic" or "")
                        
                        -- Send webhook for Secret pets or Super Legendary
                        if (pet.Shiny and pet.Mythic) or (pet.Name == "Super" or pet.Super) then
                            if now - (_webhookCooldown[key] or 0) > 10 then
                                _webhookCooldown[key] = now
                                task.spawn(function()
                                    local v = pet.Mythic and "Mythic " or pet.Shiny and "Shiny " or pet.XL and "XL " or ""
                                    sendWebhookEmbed(pet.Name, v)
                                    log("WEBHOOK", "Sent alert for " .. pet.Name)
                                end)
                            end
                        end
                        
                        State.totalHatched += 1
                        State.lastHatched = pet.Name
                    end
                end
            end
            return orig(self, data)
        end))
        log("INIT", "Hatching hook installed")
    end
end

-- ══════════════════════════════════════════
-- HATCH LOOP
-- ══════════════════════════════════════════
local function runHatchLoop()
    log("HATCH", "Started | egg=" .. tostring(State.selectedEggName))
    
    while State.hatchRunning do
        if State.priorityActive then
            log("STATE", "Priority egg active — skipping main hatch")
            task.wait(1)
            continue
        end
        
        local targetPos = State.selectedEggPos or EGG_POSITIONS[State.selectedEggName]
        if not targetPos then
            State.action = "No position for " .. State.selectedEggName
            task.wait(1)
            continue
        end
        
        State.action = "Hatching " .. State.selectedEggName
        
        local chr = lp.Character
        local hrp = chr and chr:FindFirstChild("HumanoidRootPart")
        if hrp and (hrp.Position - targetPos).Magnitude > 8 then
            tp(targetPos, "hatch_loop:" .. State.selectedEggName)
            task.wait(0.2)
        end
        
        -- Spam E to hatch
        if State.hatchRunning then
            for _ = 1, 20 do
                if not State.hatchRunning then break end
                pressE()
                task.wait(State.spamEInterval)
            end
        end
        
        task.wait(0.1)
    end
    
    State.action = "Idle"
    log("HATCH", "Stopped")
end


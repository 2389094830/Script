        State.selectedEggName = eggName
        State.selectedEggPos = EGG_POSITIONS[eggName]
        log("API", "Selected egg: " .. eggName)
        
        if State.hatchRunning then
            -- Restart hatch loop with new egg
            State.hatchRunning = false
            task.wait(0.1)
            State.hatchRunning = true
            task.spawn(runHatchLoop)
        end
    end,
    
    startHatch = function()
        if not State.hatchRunning then
            if not EGG_POSITIONS[State.selectedEggName] then
                warn("[BOT] No position for " .. State.selectedEggName)
                return
            end
            State.hatchRunning = true
            task.spawn(runHatchLoop)
            log("API", "Hatch started")
        end
    end,
    
    stopHatch = function()
        State.hatchRunning = false
        State.action = "Idle"
        log("API", "Hatch stopped")
    end,
    
    setPriority = function(eggName)
        if eggName then
            State.priorityEggName = eggName
            State.priorityActive = true
            log("API", "Priority set to: " .. eggName)
        else
            State.priorityActive = false
            log("API", "Priority cleared")
        end
    end,
    
    getStatus = function()
        return {
            action = State.action,
            eggName = State.selectedEggName,
            totalHatched = State.totalHatched,
            lastHatched = State.lastHatched,
            running = State.hatchRunning,
        }
    end,
}


local debugLog = {}
local function log(cat, msg)
    local entry = string.format("[%s][%s] %s", os.date("!%H:%M:%S"), cat, tostring(msg))
    table.insert(debugLog, 1, entry)
    if #debugLog > 400 then table.remove(debugLog) end
    if cat == "TP" or cat == "STATE" or cat == "HATCH" or cat == "QUEST" or cat == "WEBHOOK" then
        print(entry)
    end
end

local function getLog() return table.concat(debugLog, "\n") end
local function clearLog() debugLog = {} end

